{
    "name": "validators/laravel-ae",
    "description": "Laravel validation rules for UAE validators.",
    "version": "1.0.2",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mohammedelkarsh/validators",
    "support": {
        "issues": "https://github.com/mohammedelkarsh/validators/issues",
        "source": "https://github.com/mohammedelkarsh/validators"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "validators/ae": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Validators\\LaravelAe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Validators\\LaravelAe\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Validators\\LaravelAe\\ValidatorsServiceProvider"
            ]
        }
    }
}
